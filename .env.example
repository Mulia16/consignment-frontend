# ══════════════════════════════════════════════════════════
# Alpro Consignment Frontend — Environment Configuration
# ══════════════════════════════════════════════════════════

# App Mode: dev (slicing/bypass login) | stage | prod
APP_MODE=dev

# Server
SERVER_PORT=8800

# API Gateway
GATEWAY_BASE_URL=http://localhost:8080

# ══════════════════════════════════════════════════════════
# Service Paths (via API Gateway)
# Aligned with backend API architecture (see plans/api-endpoint.md)
# ══════════════════════════════════════════════════════════

# Auth Service - 3 endpoints (login, register, validate)
SERVICE_AUTH=/auth

# Consignment Service - 56 endpoints
# Includes: Consignment, Setup, CSA, CSO, CSR, CSRQ, CSRV, CSDO, Settlement, Reports
SERVICE_CONSIGNMENT=/api

# Inventory Service - 2 endpoints (availability, reserve)
SERVICE_INVENTORY=/api/v1/inventory

# Batch Job Service - 2 endpoints (settlement job, report job)
SERVICE_BATCH=/batch

# JWT
JWT_SECRET=your-jwt-secret-here
