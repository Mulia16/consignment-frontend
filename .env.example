
# App Mode: dev (slicing/bypass login) | stage | prod
APP_MODE=dev

# Server
SERVER_PORT=8800

# API Gateway
GATEWAY_BASE_URL=http://localhost:8080

# Service Paths (via API Gateway)
SERVICE_AUTH=/auth
SERVICE_MASTER_DATA=/api/master-data
SERVICE_SETUP=/api/setup
SERVICE_INVENTORY=/api/inventory
SERVICE_INBOUND=/api/inbound
SERVICE_OUTBOUND=/api/outbound
SERVICE_RETURNS=/api/returns
SERVICE_POS=/api/pos
SERVICE_SETTLEMENT=/api/settlement
SERVICE_AUDIT=/api/audit
SERVICE_BATCH=/api/batch
SERVICE_EMAIL=/api/email
SERVICE_REPORTS=/api/reports

# JWT
JWT_SECRET=your-jwt-secret-here
